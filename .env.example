# =============================================================================
#  ECOMMERCE CAPSTONE — LOCAL ENVIRONMENT VARIABLES
# .env.example as the template to share for .env file creation
# =============================================================================


# ── MySQL credentials (shared across all services) ────────────────────────────
SPRING_DATASOURCE_USERNAME=ecommerce
SPRING_DATASOURCE_PASSWORD=ecommerce123


# ── Per-service MySQL DB URLs ─────────────────────────────────────────────────
USER_DB_URL=jdbc:mysql://localhost:3306/userdb?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true
PRODUCT_DB_URL=jdbc:mysql://localhost:3306/productdb?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true
ORDER_DB_URL=jdbc:mysql://localhost:3306/orderdb?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true
PAYMENT_DB_URL=jdbc:mysql://localhost:3306/paymentdb?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true


# ── MongoDB (cart-service) ────────────────────────────────────────────────────
SPRING_DATA_MONGODB_URI=mongodb://root:rootpassword@localhost:27017/cartdb?authSource=admin


# ── Redis ─────────────────────────────────────────────────────────────────────
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379


# ── Kafka ─────────────────────────────────────────────────────────────────────
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092


# ── Elasticsearch ─────────────────────────────────────────────────────────────
SPRING_ELASTICSEARCH_URIS=http://localhost:9200


# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Change both before going to production.
JWT_SECRET=myVerySecretKeyThatShouldBeChangedInProductionAtLeast32Chars!


# ── Internal service URLs ─────────────────────────────────────────────────────
USER_SERVICE_URL=http://localhost:8081
PRODUCT_SERVICE_URL=http://localhost:8082
CART_SERVICE_URL=http://localhost:8083
ORDER_SERVICE_URL=http://localhost:8084
PAYMENT_SERVICE_URL=http://localhost:8085


# ── Stripe ────────────────────────────────────────────────────────────────────
# Get your secret key from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_KEY

# Where Stripe redirects the user after checkout completes
STRIPE_SUCCESS_URL=http://localhost:8080/api/payments/stripe/callback
STRIPE_CANCEL_URL=http://localhost:3000/payment-cancelled


# ── Email / SMTP (notification-service) ──────────────────────────────────────
# Gmail: enable 2FA → https://myaccount.google.com/apppasswords → generate app password
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=E-Commerce Team
SPRING_MAIL_PASSWORD=put your apps password
FROM_EMAIL= example@gmail.com